{
  "name": "terminal-app",
  "main": "worker/index.ts",
  "compatibility_date": "2025-04-03",
  "observability": {
    "enabled": true
  },
  "containers": [
    {
      "name": "Sandbox",
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "max_instances": 10
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "Sandbox",
        "name": "Sandbox"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "Sandbox"
      ]
    }
  ]
}


{
  "name": "myfilepath",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/acoyfellow/filepath"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.39",
    "@better-auth/api-key": "^1.5.4",
    "@better-auth/passkey": "^1.5.4",
    "@cloudflare/sandbox": "^0.8.4",
    "@simplewebauthn/browser": "^13.2.2",
    "@simplewebauthn/server": "^13.2.3",
    "agents": "^0.7.5",
    "bits-ui": "^2.16.2",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "effect": "^4.0.0-beta.28",
    "form-data": "^4.0.5",
    "node-fetch": "^3.3.2",
    "shiki": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@internationalized/date": "^3.11.0",
    "@lucide/svelte": "^0.561.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.3",
    "alchemy": "^0.87.0",
    "better-auth": "^1.5.4",
    "better-sqlite3": "^12.6.2",
    "bun": "^1.3.10",
    "bun-types": "^1.3.10",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "eslint": "^10.1.0",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "paneforge": "^1.0.2",
    "playwright": "^1.58.2",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "wrangler": "^4.69.0",
    "ws": "^8.19.0"
  },
  "description": "Personal Cloudflare-hosted development environment for bounded background agents",
  "keywords": [
    "agents",
    "sveltekit",
    "background-agents",
    "cloudflare",
    "durable-objects",
    "sandboxes",
    "hono",
    "workspaces"
  ],
  "scripts": {
    "dev": "node ./scripts/dev-preflight.mjs && alchemy dev",
    "dev:stop": "node ./scripts/dev-stop.mjs",
    "dev:wait": "node ./scripts/wait-for-local-dev.mjs",
    "smoke:local": "node ./scripts/local-smoke.mjs",
    "deploy": "NODE_ENV=production alchemy deploy --stage prod",
    "deploy:preview": "alchemy deploy",
    "destroy": "alchemy destroy",
    "d1:destroy": "wrangler d1 delete filepath-db",
    "state:clear-d1": "ALCHEMY_D1_SKIP_DELETE_API=1 NODE_ENV=production bunx alchemy destroy --stage prod alchemy.state-clear-d1.ts",
    "d1:fresh": "wrangler d1 delete filepath-db -y && bun run deploy",
    "build": "FILEPATH_VERIFY_BUILD=1 vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo \"\" && ./hooks/install.sh || echo \"\"",
    "lint": "eslint .",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "postinstall": "bun ./scripts/patch-alchemy-cli.js"
  },
  "type": "module"
}

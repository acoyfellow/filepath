{
  "name": "terminal-app",
  "version": "1.0.0",
  "description": "Minimal terminal app using Cloudflare Sandbox",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.dev.json --port 8788",
    "dev:container": "PORT=8085 node container_src/server.js",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "echo 'Add test harnesses as needed' && exit 0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.35.0"
  },
  "dependencies": {
    "@cloudflare/sandbox": "^0.6.9",
    "@cloudflare/workers-types": "^4.0.0",
    "alchemy": "^0.83.0",
    "hono": "^4.0.0"
  }
}

  "description": "Chat-first durable agent sessions backed by Cloudflare sandboxes",
  "keywords": [
    "agents",
    "sveltekit",
    "better-auth",
    "cloudflare",
    "durable-objects",
    "sandboxes"
  ],
  "scripts": {
    "dev": "alchemy dev",
    "deploy": "NODE_ENV=production alchemy deploy --stage prod",
    "deploy:preview": "alchemy deploy",
    "destroy": "alchemy destroy",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo \"\" && ./hooks/install.sh || echo \"\"",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "bun run prd.ts",
    "prd": "bun run prd.ts",
    "prd:loop": "bun run prd.ts --loop",
    "postinstall": "bun ./scripts/patch-alchemy-cli.js"
  },
  "type": "module"
}

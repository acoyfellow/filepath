# Alchemy Infrastructure
ALCHEMY_PASSWORD=your-alchemy-password
ALCHEMY_STATE_TOKEN=your-state-token

# Better Auth
# Local dev can use a placeholder secret; production must use a random 32+ character secret.
BETTER_AUTH_SECRET=dev-secret-not-for-production
BETTER_AUTH_URL=http://localhost:5173

# Cloudflare (https://dash.cloudflare.com/profile/api-tokens)
CLOUDFLARE_EMAIL=your-email@example.com
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# Email Sending
# Configured via Cloudflare Email Service (dashboard → Compute → Email Service → Email Sending).
# No runtime env vars needed — the `env.EMAIL` Worker binding is wired via alchemy.run.ts.
# One-time setup: onboard myfilepath.com in the dashboard, approve the auto-written DNS records.
# In local dev, OTPs are logged to the console instead of being sent.

# OpenAI (optional; only used by legacy OpenAI SDK integrations in tests)
OPENAI_API_KEY=sk-...

# Model inference is BYOK per-user at /settings/ai — no system-wide LLM keys.
